DOCKER_IMAGE_NAME=zook
DEPLOY_SLOT=dev
COMPOSE_PROJECT_NAME=zook-dev
DEPLOY_HOST_BIND_IP=127.0.0.1
DEPLOY_HOST_PORT=3101
DEPLOY_CONTAINER_PORT=3100
ADMIN_HOST_PORT=3111
ADMIN_CONTAINER_PORT=3111
HEALTH_PATH=api/health
ADMIN_HEALTH_PATH=_admin/health
DATABASE_URL=postgresql://replace-me:replace-me@host.docker.internal:5432/zook_dev?schema=public
REDIS_URL=redis://:replace-me@host.docker.internal:6380/0
ADMIN_DEFAULT_APP_ID=app_a
ADMIN_BRAND_NAME=Zook Control Room
ADMIN_BASIC_AUTH_USERNAME=admin
ADMIN_BASIC_AUTH_PASSWORD=change-me-dev
PORT=3100
DEPLOY_KEEP_RELEASES=5
DEPLOY_BUILDER_PRUNE_UNTIL=168h

# Add your dev environment variables below.
# ACCESS_TOKEN_SECRET=replace-me
# REFRESH_TOKEN_SECRET=replace-me
# Make sure PostgreSQL and Redis listen on an address reachable from Docker,
# not only 127.0.0.1, when using host.docker.internal.
BAILIAN_API_KEY=mock-bailian-api-key
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
GEO_RESOLVER_URL=https://geo.example.com/lookup
# GEO_RESOLVER_TOKEN=replace-me
GEO_RESOLVER_TIMEOUT_MS=1500
