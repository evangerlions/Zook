DOCKER_IMAGE_NAME=zook
DEPLOY_SLOT=online
COMPOSE_PROJECT_NAME=zook-online
DEPLOY_HOST_BIND_IP=127.0.0.1
DEPLOY_HOST_PORT=3100
DEPLOY_CONTAINER_PORT=3100
ADMIN_HOST_PORT=3110
ADMIN_CONTAINER_PORT=3110
HEALTH_PATH=api/health
ADMIN_HEALTH_PATH=_admin/health
REDIS_URL=redis://:replace-me@127.0.0.1:6379/0
ADMIN_DEFAULT_APP_ID=app_a
ADMIN_BRAND_NAME=Zook Control Room
ADMIN_BASIC_AUTH_USERNAME=admin
ADMIN_BASIC_AUTH_PASSWORD=change-me-online
PORT=3100
DEPLOY_KEEP_RELEASES=5
DEPLOY_BUILDER_PRUNE_UNTIL=168h

# Add your online environment variables below.
# ACCESS_TOKEN_SECRET=replace-me
# REFRESH_TOKEN_SECRET=replace-me
BAILIAN_API_KEY=mock-bailian-api-key
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
