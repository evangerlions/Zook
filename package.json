{
  "name": "zook-backend-scaffold",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --experimental-transform-types src/main.ts",
    "dev:stack": "bash ./scripts/dev-stack.sh",
    "admin": "node --experimental-transform-types apps/admin-web/server.ts",
    "admin:build": "npm --prefix apps/admin-web run build",
    "admin:dev": "npm --prefix apps/admin-web run dev",
    "admin:install": "npm --prefix apps/admin-web install --include=optional",
    "admin:typecheck": "npm --prefix apps/admin-web run typecheck",
    "worker": "node --experimental-transform-types src/worker.ts",
    "test": "node --experimental-transform-types --test test/unit/*.test.ts",
    "sync:api": "bash ./scripts/sync-zook-api-contracts.sh"
  },
  "devDependencies": {
    "@types/node": "^25.3.5"
  },
  "dependencies": {
    "pg": "^8.20.0",
    "redis": "^5.11.0"
  }
}
